OPENAI_API_KEY=your-openai-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

DAYTONA_API_KEY=your-daytona-api-key
AIAND_API_KEY=your-aiand-api-key
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=moonshotai/kimi-k2.7-code
# To switch to GPT-OSS when Kimi times out: AIAND_MODEL=openai/gpt-oss-120b
USE_SANDBOXED_DETECTION=false
LLM_PROVIDER=openai
EMBEDDING_BACKEND=openai
